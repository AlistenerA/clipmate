{
  "$schema": "https://opencode.ai/config.json",

  "attachment": {
    "image": {
      "auto_resize": true,
      "max_width": 2000,
      "max_height": 2000,
      "max_base64_bytes": 5242880
    }
  },

  "mcp": {
    "file-reader": {
      "type": "local",
      "command": [
        "uv",
        "run",
        "--directory",
        "mcp_server",
        "python",
        "server.py"
      ],
      "enabled": true,
      "timeout": 60000,
      "environment": {}
    }
  },

  "permission": {
    "edit": "ask",
    "bash": "ask"
  }
}
