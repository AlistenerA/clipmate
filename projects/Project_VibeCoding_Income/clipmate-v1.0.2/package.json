{
  "name": "clipmate",
  "version": "1.0.2",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build --mode production",
    "build:staging": "tsc --noEmit && vite build --mode staging",
    "preview": "vite preview",
    "lint": "eslint src --ext .ts,.tsx",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "qa:tutorial": "node scripts/serve-tutorial-fixture.mjs",
    "qa:asset-picker": "node scripts/serve-asset-picker-fixture.mjs",
    "zip": "powershell -Command \"Add-Type -AssemblyName System.IO.Compression.FileSystem; $zip='clipmate-v1.0.2.zip'; if(Test-Path $zip){Remove-Item $zip}; [System.IO.Compression.ZipFile]::CreateFromDirectory('dist', $zip)\""
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "@vscode/vscode-languagedetection": "^1.0.23",
    "highlight.js": "^11.11.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "turndown": "^7.2.4"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.26",
    "@types/chrome": "^0.0.268",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/turndown": "^5.0.6",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.38",
    "prettier": "^3.3.2",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.2",
    "vite": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
